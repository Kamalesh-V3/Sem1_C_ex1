      case 9:
         printf("It is nine");
         break;
      case 8:
         printf("It is eight");
         break;
      case 7:
         printf("It is seven");
         break;
      case 6:
         printf("It is six");
         break;
      case 5:
         printf("It is five");
         break;
      case 4:
         printf("It is four");
         break;
      case 3:
         printf("It is three");
         break;
      case 2:
         printf("It is two");
         break;
      case 1:
         printf("It is one");
         break;
      default:
         printf("invald digit");
   }
   return 0;
}
